# Database
# PostgreSQL (REQUIRED for production)
DATABASE_URL="postgresql://username:password@localhost:5432/lawfirm_db?schema=public"
# For managed PostgreSQL (Render, Railway, etc.), use their connection string

# Server
PORT=5000
NODE_ENV=production

# JWT (CRITICAL: Generate a secure 32+ character random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
JWT_EXPIRES_IN=7d

# Email Configuration (for automated reminders & notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_NAME=Your Law Firm Name
FRONTEND_URL=https://yourdomain.com

# SMS (Termii - for urgent notifications)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=YourFirm

# File Upload (Consider using cloud storage in production)
MAX_FILE_SIZE=50MB
UPLOAD_DIR=./uploads

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# CORS (Comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

